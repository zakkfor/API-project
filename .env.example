PROJECT_NAME=Bike House
API_V1_STR=/api/v1

# --- База даних ---
# Локальна розробка: SQLite-файл у корені проекту
DATABASE_URL=sqlite:///./app.db
# Railway (SQLite з Volume, Mount Path = /data):
#   DATABASE_URL=sqlite:////data/app.db
# Railway PostgreSQL (вставте рядок підключення з вкладки Variables):
#   DATABASE_URL=postgresql://user:password@host:5432/dbname

SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SEED_USER_PASSWORD=BikeHouse2025!
# Адміністратори (формат: "username:password,username2:password2")
# Змінюй цю змінну на Railway/Render без редагування коду
ADMIN_CREDENTIALS=alex123:123456,alex12345:qwertyu,max:123456
